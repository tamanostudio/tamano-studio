      <div id="goals-future"><div class="gc " id="gc-4"><div class="gch"><input type="checkbox" class="gck" onchange="toggleGoal(4,this)"><div class="gb"><div class="gt" onclick="editGoalField(4,&#39;title&#39;)">自分の家で暮らす</div><div class="gs" onclick="editGoalField(4,&#39;sub&#39;)">ママの貸家を建て替え予定</div><div class="gp"><div class="gpb" style="width:0%;background:#9b7ea8"></div></div></div><button class="xbtn" onclick="delGoal(&#39;future&#39;,4)">×</button></div></div><div class="gc " id="gc-5"><div class="gch"><input type="checkbox" class="gck" onchange="toggleGoal(5,this)"><div class="gb"><div class="gt" onclick="editGoalField(5,&#39;title&#39;)">ランプシェードを独立した事業に</div><div class="gs" onclick="editGoalField(5,&#39;sub&#39;)">地元の和紙を使った制作</div><div class="gp"><div class="gpb" style="width:0%;background:#b8946a"></div></div></div><button class="xbtn" onclick="delGoal(&#39;future&#39;,5)">×</button></div></div><div class="gc " id="gc-6"><div class="gch"><input type="checkbox" class="gck" onchange="toggleGoal(6,this)"><div class="gb"><div class="gt" onclick="editGoalField(6,&#39;title&#39;)">大人向けワークショップを始める</div><div class="gs" onclick="editGoalField(6,&#39;sub&#39;)">少子化を見据えた教室の方向転換</div><div class="gp"><div class="gpb" style="width:0%;background:#6a7f9e"></div></div></div><button class="xbtn" onclick="delGoal(&#39;future&#39;,6)">×</button></div></div></div>
      <button class="goal-add-btn" onclick="addGoal(&#39;future&#39;)">＋ 目標を追加</button>
