<div class="save-indicator" id="save-ind">保存しました</div>
<script>
const TIMES=(()=>{const a=[];for(let h=6;h<=23;h++){const hh=String(h).padStart(2,'0');a.push(hh+':00');a.push(hh+':30');}return a;})();
function makeTimeSel(cls,def){const s=document.createElement('select');s.className=cls;TIMES.forEach(t=>{const o=document.createElement('option');o.value=t;o.textContent=t;if(t===def)o.selected=true;s.appendChild(o);});return s;}
function save(){try{localStorage.setItem('ts_todos',JSON.stringify(todos));localStorage.setItem('ts_weekTasks',JSON.stringify(weekTasks));localStorage.setItem('ts_dayTL',JSON.stringify(dayTL));localStorage.setItem('ts_goals',JSON.stringify(goals));localStorage.setItem('ts_shop',JSON.stringify(shop));showSaveInd();}catch(e){}}
function load(){try{const t=localStorage.getItem('ts_todos');if(t)todos.push(...JSON.parse(t));const w=localStorage.getItem('ts_weekTasks');if(w){const d=JSON.parse(w);d.forEach((v,i)=>{weekTasks[i]=v;});}const dl=localStorage.getItem('ts_dayTL');if(dl){const d=JSON.parse(dl);d.forEach((v,i)=>{dayTL[i]=v;});}const g=localStorage.getItem('ts_goals');if(g){const d=JSON.parse(g);goals.year=d.year;goals.future=d.future;}const sh=localStorage.getItem('ts_shop');if(sh)shop.push(...JSON.parse(sh));}catch(e){}}
function showSaveInd(){const el=document.getElementById('save-ind');el.classList.add('show');clearTimeout(el._t);el._t=setTimeout(()=>el.classList.remove('show'),1500);}
function sw(n,b){document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));document.querySelectorAll('.sec').forEach(s=>s.classList.remove('on'));b.classList.add('on');document.getElementById('s-'+n).classList.add('on');if(n==='todo')renderGoalSelect();}
const DAY=['月','火','水','木','金','土','日'];
const DAY_TAG=[{cls:'t-rest',lbl:'休み'},{cls:'t-work',lbl:'制作日'},{cls:'t-work',lbl:'制作日'},{cls:'t-buf',lbl:'予備日'},{cls:'t-cls',lbl:'教室'},{cls:'t-cls',lbl:'教室'},{cls:'t-cls',lbl:'教室'}];
const FIXED=[['回復・読書'],['張り子','ランプシェード'],['張り子','ランプシェード'],['急な仕事','納品','デザイン'],['9:00〜17:30','片付け','動画準備'],['9:00〜17:30'],['9:00〜17:30']];
const GOAL_COLORS=['#a0856c','#6b8fa3','#7a9e7e','#9b7ea8','#b8946a','#6a7f9e'];
const todos=[],weekTasks=Array.from({length:14},()=>[]),dayTL=Array.from({length:14},()=>[]);
let drag=null,tlDrag=null,gid=100,curPlace='all';
const shop=[];
const goals={year:[{id:1,title:'11月 展示会',sub:'新しい張り子 + ランプシェードのお披露目',progress:15,done:false},{id:2,title:'夏までに本店オープン',sub:'教室の片隅に — 倉庫片付け中',progress:20,done:false},{id:3,title:'家の貯金を増やす',sub:'月10万 + 副収入年50万を目標に',progress:30,done:false}],future:[{id:4,title:'自分の家で暮らす',sub:'ママの貸家を建て替え予定',progress:0,done:false},{id:5,title:'ランプシェードを独立した事業に',sub:'地元の和紙を使った制作',progress:0,done:false},{id:6,title:'大人向けワークショップを始める',sub:'少子化を見据えた教室の方向転換',progress:0,done:false}]};
function allGoals(){return [...goals.year,...goals.future];}
function findGoal(id){return allGoals().find(g=>g.id===id);}
function goalColor(id){return GOAL_COLORS[allGoals().findIndex(g=>g.id===id)%GOAL_COLORS.length];}
function esc(s){return String(s||'').replace(/\\/g,'\\\\').replace(/'/g,'\\x27');}
function clearInp(inp){inp.value='';setTimeout(()=>{inp.value='';},0);}
function buildInputUI(wrapId,ph,btnLbl,onAdd){const wrap=document.getElementById(wrapId);if(!wrap)return;wrap.innerHTML='';const row=document.createElement('div');row.style='display:flex;gap:5px;margin-top:8px;';const inp=document.createElement('input');inp.type='text';inp.placeholder=ph;inp.style='font-family:Jost,sans-serif;font-size:13px;flex:1;padding:7px 10px;border:.5px solid var(--border);border-radius:10px;background:#fff;color:#2a2520;outline:none;min-width:0;';const btn=document.createElement('button');btn.textContent=btnLbl;btn.style='font-family:Jost,sans-serif;font-size:12px;padding:7px 14px;border:.5px solid var(--border);border-radius:10px;background:#fff;color:#2a2520;cursor:pointer;white-space:nowrap;';const doAdd=()=>{const v=inp.value.trim();if(!v)return;onAdd(v);clearInp(inp);};btn.onclick=doAdd;inp.onkeydown=e=>{if(e.key==='Enter'){e.preventDefault();doAdd();}};row.append(inp,btn);wrap.append(row);}
function buildShopInputUI(){const wrap=document.getElementById('si-wrap');if(!wrap)return;wrap.innerHTML='';const row=document.createElement('div');row.style='display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap;';const inp=document.createElement('input');inp.type='text';inp.placeholder='アイテム名...';inp.style='font-family:Jost,sans-serif;font-size:13px;flex:1;padding:7px 10px;border:.5px solid var(--border);border-radius:10px;background:#fff;color:#2a2520;outline:none;min-width:100px;';const sel=document.createElement('select');sel.style='font-family:Jost,sans-serif;font-size:13px;padding:7px 10px;border:.5px solid var(--border);border-radius:10px;background:#fff;color:#2a2520;outline:none;';['ダイソー','セリア','ホームセンター','ネット','その他'].forEach(p=>{const o=document.createElement('option');o.value=o.textContent=p;sel.append(o);});const btn=document.createElement('button');btn.textContent='追加';btn.style='font-family:Jost,sans-serif;font-size:12px;padding:7px 14px;border:.5px solid var(--border);border-radius:10px;background:#fff;color:#2a2520;cursor:pointer;white-space:nowrap;';const doAdd=()=>{const t=inp.value.trim();if(!t)return;shop.push({t,p:sel.value,bought:false,id:Date.now()});clearInp(inp);rPTabs();renderShop();save();};btn.onclick=doAdd;inp.onkeydown=e=>{if(e.key==='Enter'){e.preventDefault();doAdd();}};row.append(inp,sel,btn);wrap.append(row);}
function addTodo(text,goalId){if(!text.trim())return;todos.push({id:Date.now(),text:text.trim(),done:false,goalId:goalId||null});renderTodoList();renderGoals();save();}
function toggleTodo(id){const t=todos.find(x=>x.id===id);if(t){t.done=!t.done;renderTodoList();renderGoals();save();}}
function deleteTodo(id){todos.splice(todos.findIndex(x=>x.id===id),1);renderTodoList();renderGoals();save();}
function renderTodoList(){const el=document.getElementById('todo-list');if(!el)return;el.innerHTML=todos.map(x=>{const g=x.goalId?findGoal(x.goalId):null;const col=g?goalColor(x.goalId):'';const wkDates0=getWeekDates(0),wkDates1=getWeekDates(1);return `<div class="litem ${x.done?'done':''}"><span class="drag-handle">⠿</span><input type="checkbox" ${x.done?'checked':''} onchange="toggleTodo(${x.id})"><span class="ttext" style="flex:1">${x.text}</span>${g?`<span class="goal-tag" style="background:${col}">${g.title}</span>`:''}<button class="add-to-week-btn" onclick="toggleDayPicker('dpanel-${x.id}')">週間へ＋</button><button class="xbtn" onclick="deleteTodo(${x.id})">×</button></div><div class="day-picker-panel" id="dpanel-${x.id}"><div class="day-picker-label">今週</div><div class="day-picker-btns">${DAY.map((d,i)=>`<button class="day-pick-btn" onclick="addToWeek('${esc(x.text)}',${i},'dpanel-${x.id}')">${d}<br><span style="font-size:9px">${wkDates0[i]}</span></button>`).join('')}</div><div class="day-picker-label" style="margin-top:6px">来週</div><div class="day-picker-btns">${DAY.map((d,i)=>`<button class="day-pick-btn" onclick="addToWeek('${esc(x.text)}',${7+i},'dpanel-${x.id}')">${d}<br><span style="font-size:9px">${wkDates1[i]}</span></button>`).join('')}</div></div>`;}).join('');}
function toggleDayPicker(id){document.querySelectorAll('.day-picker-panel').forEach(p=>{if(p.id!==id)p.classList.remove('show');});document.getElementById(id).classList.toggle('show');}
function addToWeek(text,idx,panelId){if(!weekTasks[idx].includes(text)){weekTasks[idx].push(text);renderChips(idx);renderDayPool(idx);save();}document.getElementById(panelId).classList.remove('show');}
function renderGoalSelect(){const sel=document.getElementById('ti-goal');if(!sel)return;const cur=sel.value;sel.innerHTML='<option value="">なし</option>'+allGoals().map(g=>`<option value="${g.id}">${g.title}</option>`).join('');sel.value=cur;}
function renderFixed(){document.getElementById('fixed-week').innerHTML=DAY.map((d,i)=>`<div class="fw-col"><div class="fw-day">${d}</div><div class="fw-tag ${DAY_TAG[i].cls}">${DAY_TAG[i].lbl}</div><div class="fw-items">${FIXED[i].map(t=>`<div>${t}</div>`).join('')}</div></div>`).join('');}
function getWeekDates(off){const today=new Date();const dow=today.getDay();const mo=new Date(today);mo.setDate(today.getDate()+(dow===0?-6:1-dow)+(off*7));return Array.from({length:7},(_,i)=>{const d=new Date(mo);d.setDate(mo.getDate()+i);return `${d.getMonth()+1}/${d.getDate()}`;});}
function renderTaskList(){const w0=getWeekDates(0),w1=getWeekDates(1);let html='';[[w0,0,'今週'],[w1,7,'来週']].forEach(([dates,off,lbl])=>{html+=`<div class="week-divider" style="margin-top:${off?'1rem':'0'}"><span>${lbl}</span><hr></div>`;html+=DAY.map((d,i)=>{const idx=off+i;return `<div class="tw-row" id="tw-${idx}" ondragover="event.preventDefault();this.classList.add('drag-over')" ondragleave="this.classList.remove('drag-over')" ondrop="dropDay(event,${idx})"><div class="tw-day-label"><span class="tw-day-name">${d}</span><span style="font-size:9px;color:var(--text2);display:block;margin-top:1px">${dates[i]}</span><span class="tw-day-tag ${DAY_TAG[i].cls}">${DAY_TAG[i].lbl}</span></div><div class="tw-tasks-col" id="twt-${idx}"></div><div class="tw-actions"><button class="open-day-btn" onclick="openDay(${idx})">時間割→</button></div></div>`;}).join('');});document.getElementById('task-list').innerHTML=html;for(let i=0;i<14;i++)renderChips(i);}
function renderChips(i){const el=document.getElementById('twt-'+i);if(!el)return;el.innerHTML=weekTasks[i].map((t,j)=>`<div class="tw-chip" draggable="true" ondragstart="drag={type:'chip',text:'${esc(t)}',di:${i},ti:${j}};this.classList.add('dragging')" ondragend="drag=null;this.classList.remove('dragging')"><span>${t}</span><button class="xbtn" style="font-size:10px" onclick="event.stopPropagation();delChip(${i},${j})">×</button></div>`).join('')+`<button class="tw-add-btn" onclick="addChipInline(${i})">＋</button>`;}
function dropDay(e,i){e.preventDefault();document.getElementById('tw-'+i).classList.remove('drag-over');if(!drag)return;if(drag.type==='chip'){if(drag.di===i){drag=null;return;}weekTasks[drag.di].splice(drag.ti,1);renderChips(drag.di);renderDayPool(drag.di);}if(!weekTasks[i].includes(drag.text)){weekTasks[i].push(drag.text);renderChips(i);renderDayPool(i);}drag=null;save();}
function delChip(i,j){weekTasks[i].splice(j,1);renderChips(i);renderDayPool(i);save();}
function addChipInline(i){const col=document.getElementById('twt-'+i);const btn=col.querySelector('.tw-add-btn');const inp=document.createElement('input');inp.className='tw-inp';inp.placeholder='タスク名...';col.insertBefore(inp,btn);inp.focus();let done=false;const fn=()=>{if(done)return;done=true;if(inp.value.trim()){weekTasks[i].push(inp.value.trim());renderChips(i);renderDayPool(i);save();}else if(inp.parentNode)inp.remove();};inp.onkeydown=e=>{if(e.key==='Enter')fn();else if(e.key==='Escape'){done=true;inp.remove();}};inp.onblur=()=>setTimeout(fn,80);}
function buildDayAreas(){const w0=getWeekDates(0),w1=getWeekDates(1);const labels=[...DAY.map((d,i)=>`${d} ${w0[i]}`),...DAY.map((d,i)=>`${d} ${w1[i]}`)];document.getElementById('day-tabs').innerHTML=labels.map((d,i)=>`<button class="dtab ${i===0?'on':''}" onclick="openDay(${i})">${d}</button>`).join('');document.getElementById('day-areas').innerHTML=Array.from({length:14},(_,i)=>`<div class="day-area ${i===0?'on':''}" id="da-${i}"><div class="day-split"><div><div class="pool-label">この日のタスク</div><div class="task-pool" id="dp-${i}" ondragover="event.preventDefault();this.classList.add('drag-over-pool')" ondragleave="this.classList.remove('drag-over-pool')" ondrop="dropPool(event,${i})"><div class="pool-empty" id="dpe-${i}">週間で割り当てると<br>ここに表示</div></div></div><div><div class="pool-label">時間割</div><div id="dtl-${i}"></div><div class="drop-zone" id="ddz-${i}" ondragover="event.preventDefault();this.classList.add('active')" ondragleave="this.classList.remove('active')" ondrop="dropTimeline(event,${i})">タスクをここにドロップ</div><div class="manual-add" id="madd-${i}"></div></div></div></div>`).join('');for(let i=0;i<14;i++){renderDayPool(i);renderTimeline(i);buildManualAdd(i);}}
function buildManualAdd(i){const wrap=document.getElementById('madd-'+i);if(!wrap)return;const sel=makeTimeSel('m-time-sel','09:00');const inp=document.createElement('input');inp.className='m-task';inp.placeholder='作業内容...';inp.autocomplete='off';const btn=document.createElement('button');btn.textContent='追加';const doAdd=()=>{const task=inp.value.trim();if(!task)return;dayTL[i].push({id:Date.now(),time:sel.value,task});dayTL[i].sort((a,b)=>a.time.localeCompare(b.time));renderTimeline(i);renderDayPool(i);clearInp(inp);save();};btn.onclick=doAdd;inp.onkeydown=e=>{if(e.key==='Enter'){e.preventDefault();doAdd();}};wrap.append(sel,inp,btn);}
function openDay(i){document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));document.querySelectorAll('.sec').forEach(s=>s.classList.remove('on'));document.querySelectorAll('.tab')[1].classList.add('on');document.getElementById('s-day').classList.add('on');document.querySelectorAll('.dtab').forEach(t=>t.classList.remove('on'));document.querySelectorAll('.day-area').forEach(a=>a.classList.remove('on'));document.querySelectorAll('.dtab')[i].classList.add('on');document.getElementById('da-'+i).classList.add('on');}
function renderDayPool(i){const pool=document.getElementById('dp-'+i),empty=document.getElementById('dpe-'+i);if(!pool)return;pool.querySelectorAll('.pool-item').forEach(el=>el.remove());const inTl=new Set(dayTL[i].map(r=>r.task));const avail=weekTasks[i].filter(t=>!inTl.has(t));if(empty)empty.style.display=avail.length?'none':'block';avail.forEach(t=>{const el=document.createElement('div');el.className='pool-item';el.draggable=true;el.textContent=t;el.ondragstart=()=>{drag={type:'pool',text:t};el.classList.add('dragging');};el.ondragend=()=>{drag=null;el.classList.remove('dragging');};pool.append(el);});}
function dropPool(e,i){e.preventDefault();document.getElementById('dp-'+i).classList.remove('drag-over-pool');if(!drag||drag.type!=='todo')return;if(!weekTasks[i].includes(drag.text)){weekTasks[i].push(drag.text);renderChips(i);renderDayPool(i);}drag=null;save();}
function dropTimeline(e,i){e.preventDefault();const dz=document.getElementById('ddz-'+i);dz.classList.remove('active');if(!drag||drag.type!=='pool')return;const taskName=drag.text;drag=null;const sel=makeTimeSel('dz-sel','09:00');const ok=document.createElement('button');ok.className='dz-ok';ok.textContent='追加';const cx=document.createElement('button');cx.className='dz-cx';cx.textContent='キャンセル';const lbl=document.createElement('div');lbl.className='dz-lbl';lbl.textContent=`「${taskName}」— 時間を選択`;const row=document.createElement('div');row.className='dz-row';row.append(sel,ok,cx);dz.className='dz-form';dz.innerHTML='';dz.append(lbl,row);ok.onclick=()=>{const time=sel.value;dz.className='drop-zone';dz.textContent='タスクをここにドロップ';if(time){dayTL[i].push({id:Date.now(),time,task:taskName});dayTL[i].sort((a,b)=>a.time.localeCompare(b.time));renderTimeline(i);renderDayPool(i);save();}};cx.onclick=()=>{dz.className='drop-zone';dz.textContent='タスクをここにドロップ';};}
function renderTimeline(i){const c=document.getElementById('dtl-'+i);if(!c)return;c.innerHTML='';dayTL[i].forEach((r,j)=>{const row=document.createElement('div');row.className='tl-row';row.draggable=true;row.ondragstart=()=>{tlDrag={di:i,ti:j};row.classList.add('dragging');};row.ondragend=()=>{tlDrag=null;document.querySelectorAll('.tl-row').forEach(x=>x.classList.remove('drag-over-tl'));};row.ondragover=e=>{e.preventDefault();row.classList.add('drag-over-tl');};row.ondrop=e=>{e.preventDefault();document.querySelectorAll('.tl-row').forEach(x=>x.classList.remove('drag-over-tl'));if(!tlDrag||tlDrag.di!==i)return;const[r2]=dayTL[i].splice(tlDrag.ti,1);dayTL[i].splice(j,0,r2);renderTimeline(i);tlDrag=null;save();};const tc=document.createElement('div');tc.className='tl-time-col';const ts=document.createElement('span');ts.className='tl-time-disp';ts.textContent=r.time;tc.append(ts);const tx=document.createElement('span');tx.className='tl-task-text';tx.textContent=r.task;const xb=document.createElement('button');xb.className='xbtn';xb.style.marginLeft='8px';xb.textContent='×';xb.onclick=()=>{dayTL[i].splice(j,1);renderTimeline(i);renderDayPool(i);save();};row.append(tc,tx,xb);c.append(row);});}
function renderGoals(){['year','future'].forEach(grp=>{const el=document.getElementById('goals-'+grp);if(!el)return;el.innerHTML=goals[grp].map(g=>{const linked=todos.filter(t=>t.goalId===g.id);const done=linked.filter(t=>t.done).length;const pct=linked.length?Math.round(done/linked.length*100):g.progress;const col=goalColor(g.id);return `<div class="gc ${g.done?'chk':''}" id="gc-${g.id}"><div class="gch"><input type="checkbox" class="gck" ${g.done?'checked':''} onchange="toggleGoal(${g.id},this)"><div class="gb"><div class="gt" onclick="editGoalField(${g.id},'title')">${g.title}</div><div class="gs" onclick="editGoalField(${g.id},'sub')">${g.sub||'— 説明を追加'}</div>${linked.length?`<div class="g-todos">${linked.map(t=>`<span class="g-todo-chip ${t.done?'done-chip':''}">${t.text}</span>`).join('')}</div>`:''}<div class="gp"><div class="gpb" style="width:${pct}%;background:${col}"></div></div></div><button class="xbtn" onclick="delGoal('${grp}',${g.id})">×</button></div></div>`;}).join('');});}
function editGoalField(id,field){const g=findGoal(id);if(!g)return;const gc=document.getElementById('gc-'+id);if(!gc)return;const target=gc.querySelector(field==='title'?'.gt':'.gs');if(!target)return;const inp=document.createElement('input');inp.className=field==='title'?'g-edit-inp':'g-edit-sub';inp.value=g[field]||'';inp.placeholder=field==='title'?'目標':'説明';target.replaceWith(inp);inp.focus();inp.select();let saved=false;const fn=()=>{if(saved)return;saved=true;if(inp.value.trim())g[field]=inp.value.trim();renderGoals();save();};inp.onkeydown=e=>{if(e.key==='Enter'||e.key==='Escape')fn();};inp.onblur=fn;}
function toggleGoal(id,cb){const g=findGoal(id);if(g){g.done=cb.checked;renderGoals();save();}}
function delGoal(grp,id){goals[grp]=goals[grp].filter(g=>g.id!==id);renderGoals();renderGoalSelect();save();}
function addGoal(grp){const newG={id:++gid,title:'新しい目標',sub:'',progress:0,done:false};goals[grp].push(newG);renderGoals();renderGoalSelect();save();setTimeout(()=>editGoalField(newG.id,'title'),30);}
function tS(id){const x=shop.find(i=>i.id===id);if(x){x.bought=!x.bought;renderShop();save();}}
function dS(id){shop.splice(shop.findIndex(i=>i.id===id),1);rPTabs();renderShop();save();}
function rPTabs(){const places=[...new Set(shop.map(i=>i.p))];document.getElementById('ptabs').innerHTML=`<button class="ptab ${curPlace==='all'?'on':''}" onclick="filterP('all',this)">すべて</button>`+places.map(p=>`<button class="ptab ${curPlace===p?'on':''}" onclick="filterP('${p}',this)">${p}</button>`).join('');}
function filterP(p,btn){curPlace=p;document.querySelectorAll('.ptab').forEach(t=>t.classList.remove('on'));btn.classList.add('on');renderShop();}
function renderShop(){const c=document.getElementById('sl'),f=curPlace==='all'?shop:shop.filter(i=>i.p===curPlace);c.innerHTML=f.map(i=>`<div class="sitem ${i.bought?'bought':''}"><input type="checkbox" ${i.bought?'checked':''} onchange="tS(${i.id})"><span class="sname" style="flex:1">${i.t}</span>${curPlace==='all'?`<span class="pbadge">${i.p}</span>`:''}<button class="xbtn" onclick="dS(${i.id})">×</button></div>`).join('');}
load();renderFixed();renderTaskList();buildDayAreas();renderGoals();renderGoalSelect();renderTodoList();
buildInputUI('ti-wrap','追加する...','追加',text=>{const sel=document.getElementById('ti-goal');addTodo(text,sel&&sel.value?parseInt(sel.value):null);});
buildShopInputUI();rPTabs();renderShop();
const now=new Date(),days=['日','月','火','水','木','金','土'];
document.getElementById('dt').textContent=`${now.getFullYear()}.${String(now.getMonth()+1).padStart(2,'0')}.${String(now.getDate()).padStart(2,'0')} ${days[now.getDay()]}`;
</script>


