    <div id="si-wrap"><div style="display: flex; gap: 8px; margin-bottom: 10px; flex-wrap: wrap;"><input type="text" placeholder="アイテム名..." style="font-family: Jost, sans-serif; font-size: 13px; flex: 1 1 0%; padding: 7px 10px; border: .5px solid var(--border); border-radius: 10px; background: rgb(255, 255, 255); color: rgb(42, 37, 32); outline: none; min-width: 100px;"><select style="font-family: Jost, sans-serif; font-size: 13px; padding: 7px 10px; border: .5px solid var(--border); border-radius: 10px; background: rgb(255, 255, 255); color: rgb(42, 37, 32); outline: none;"><option value="ダイソー">ダイソー</option><option value="セリア">セリア</option><option value="ホームセンター">ホームセンター</option><option value="ネット">ネット</option><option value="その他">その他</option></select><button style="font-family: Jost, sans-serif; font-size: 12px; padding: 7px 14px; border: .5px solid var(--border); border-radius: 10px; background: rgb(255, 255, 255); color: rgb(42, 37, 32); cursor: pointer; white-space: nowrap;">追加</button></div></div>
